# Copie para .env.local. Em desenvolvimento, rode `npx supabase status`
# e cole os valores locais. Em produção, use as chaves do projeto na nuvem.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Lembretes automáticos por WhatsApp (Z-API)
REMINDER_HOURS_BEFORE=3
CRON_SECRET=
# Deixe vazio para modo simulação (não envia, só registra no log).
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
